{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./skill-registry.schema.json",
  "title": "make-docs skill registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["skills"],
  "properties": {
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "source",
          "entryPoint",
          "installName",
          "required",
          "description",
          "assets"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "pattern": "^(https?://|github:|url:).+"
          },
          "entryPoint": {
            "type": "string",
            "minLength": 1
          },
          "installName": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          },
          "assets": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["source", "installPath"],
              "properties": {
                "source": {
                  "type": "string",
                  "minLength": 1
                },
                "installPath": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    }
  }
}
